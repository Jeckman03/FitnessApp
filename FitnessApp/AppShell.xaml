<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FitnessApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FitnessApp"
    xmlns:views="clr-namespace:FitnessApp.Views"
    Title="FitnessApp">

    <TabBar CurrentItem="{x:Reference HomeTab}">
        <Tab Title="Workout">
            <ShellContent ContentTemplate="{DataTemplate views:WorkoutPage}" />
        </Tab>
        
        <Tab x:Name="HomeTab" Title="Home">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="History">
            <ShellContent ContentTemplate="{DataTemplate views:HistoryPage}" />
        </Tab>
    </TabBar>

</Shell>
